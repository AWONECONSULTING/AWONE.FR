<section class="ig-section" aria-labelledby="instagram-title">
  <div class="ig-feed-layout">
    <div class="ig-intro reveal">
      <p class="eyebrow">Social culture — en direct</p>
      <h2 id="instagram-title" class="sec">Dans les coulisses d'AWONE.</h2>
      <p class="lead">
        Projets, créations et moments d'équipe : découvrez notre univers au
        rythme de nos dernières publications.
      </p>

      <a class="ig-profile-card" href="https://www.instagram.com/awone.fr/" target="_blank" rel="noopener noreferrer">
        <span class="ig-ring" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.4" cy="6.6" r="1.15" fill="currentColor" stroke="none"/>
          </svg>
        </span>
        <span class="ig-profile-copy">
          <strong>@awone.fr</strong>
          <span>Ouvrir le profil Instagram</span>
        </span>
        <svg class="ig-profile-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="8 7 17 7 17 16"/></svg>
      </a>
    </div>

    <div class="ig-feed-shell reveal">
      <div class="ig-feed-bar" aria-hidden="true">
        <span class="ig-feed-live"><i></i> Feed en direct</span>
        <span>Instagram</span>
      </div>

      <div class="ig-feed-viewport" data-instagram-viewport>
        <div class="ig-feed-scale" data-instagram-scale>
          <iframe
            class="ig-feed-frame"
            src="https://www.instagram.com/awone.fr/embed/"
            title="Dernières publications Instagram de AWONE"
            width="520"
            height="505"
            loading="lazy"
            fetchpriority="low"
            scrolling="no"
            tabindex="-1"
            aria-hidden="true"
          ></iframe>
          <a
            class="ig-feed-overlay"
            href="https://www.instagram.com/awone.fr/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Voir le feed complet de @awone.fr sur Instagram"
          ></a>
        </div>
      </div>

      <a class="ig-feed-footer" href="https://www.instagram.com/awone.fr/" target="_blank" rel="noopener noreferrer">
        <span>Voir toutes les publications</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="8 7 17 7 17 16"/></svg>
      </a>
    </div>
  </div>
</section>

