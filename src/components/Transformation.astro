<!-- ══════════════ AVANT / APRÈS ══════════════ -->
<section data-burst id="transformation" data-tint="lavande">
  <div class="burst" aria-hidden="true"><span class="b-comet" style="--bx:25%;--by:35%;--bd:0s;--c:var(--jaune)"></span><span class="b-comet" style="--bx:75%;--by:35%;--bd:.2s;--c:var(--lavande);--sx:-260px;--rot:-135deg"></span></div>
  <div class="wrap">
    <div class="reveal" style="text-align:center">
      <p class="eyebrow">La transformation</p>
      <h2 class="sec" style="margin:0 auto">Ce qui change quand le projet est structuré</h2>
    </div>
    <div class="ba-grid">
      <article class="ba before reveal" data-i="0">
        <h3>Avant</h3>
        <ul>
          <li>Une idée forte, mais difficile à expliquer</li>
          <li>Une image pas toujours cohérente</li>
          <li>Un site ou des supports qui ne convertissent pas assez</li>
          <li>Des actions marketing dispersées</li>
          <li>Peu de visibilité sur les prochaines priorités</li>
        </ul>
      </article>
      <article class="ba after reveal" data-i="1">
        <h3>Après</h3>
        <ul>
          <li>Une offre plus claire</li>
          <li>Une image plus professionnelle</li>
          <li>Un parcours client plus fluide</li>
          <li>Des outils mieux connectés</li>
          <li>Une stratégie plus simple à piloter</li>
        </ul>
      </article>
    </div>
    <p class="method-punch reveal">On ne vend pas du rêve, on le réalise.</p>
  </div>
</section>
