<!-- ══════════════ POURQUOI AWONE ══════════════ -->
<section class="why brands-sec" id="pourquoi" data-tint="space">
  <div class="space" aria-hidden="true">
    <i class="stars s1"></i><i class="stars s2"></i>
    <span class="meteor"></span>
    <span class="impact"><i class="flash"></i><i class="wave"></i><i class="wave w2"></i><i class="sparks"></i></span>
  </div>
  <div class="wrap">
    <!-- Carrousel infini de grandes marques — focus central, swipe fluide -->
    <div class="boom bC brands" role="region" aria-label="De grandes marques, parties d'une idée">
      <div class="brands-stage">
        <button class="b-arrow prev" type="button" aria-label="Marque précédente">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="brands-track" id="brands-track" tabindex="0" aria-label="Faites défiler les marques">
          <div class="brand" style="--bg:#DA291C;--fg:#FFC72C"><span>McDonald's</span></div>
          <div class="brand" style="--bg:#0A0A0A;--fg:#FCFCFC"><span class="b-italic">NIKE</span></div>
          <div class="brand" style="--bg:#FCFCFC;--fg:#0A0A0A"><span class="b-tight">adidas</span></div>
          <div class="brand" style="--bg:#3E2B18;--fg:#D4B48C"><span class="b-caps">Louis Vuitton</span></div>
          <div class="brand" style="--bg:#FCFCFC;--fg:#0A0A0A"><span class="b-caps b-space">CHANEL</span></div>
          <div class="brand" style="--bg:#FDEAD2;--fg:#0A0A0A"><span class="b-caps b-light">JACQUEMUS</span></div>
          <div class="brand" style="--bg:#FCFCFC;--fg:#E30613"><span>Swiss Life</span></div>
          <div class="brand" style="--bg:#0A0A0A;--fg:#FCFCFC"><span class="b-caps b-space">ZARA</span></div>
          <div class="brand" style="--bg:#0A0A0A;--fg:#06C167"><span>Uber Eats</span></div>
          <div class="brand" style="--bg:#004E9F;--fg:#FCFCFC"><span>Carrefour</span></div>
          <div class="brand" style="--bg:#E30613;--fg:#FCFCFC"><span>Auchan</span></div>
          <div class="brand" style="--bg:#FCFCFC;--fg:#0A0A0A"><span class="b-tight">Apple</span></div>
          <div class="brand" style="--bg:#034EA2;--fg:#FCFCFC"><span class="b-caps">SAMSUNG</span></div>
          <div class="brand" style="--bg:#0A0A0A;--fg:#E82127"><span class="b-caps b-space">TESLA</span></div>
          <div class="brand" style="--bg:#0A0A0A;--fg:#D5001C"><span class="b-caps">PORSCHE</span></div>
          <div class="brand" style="--bg:#0A0A0A;--fg:#C8CCCE"><span class="b-caps b-light">MERCEDES</span></div>
          <div class="brand" style="--bg:#FCFCFC;--fg:#0056A3"><span>Danone</span></div>
          <div class="brand" style="--bg:#FCFCFC;--fg:#00205B"><span class="b-caps">AIRBUS</span></div>
          <div class="brand" style="--bg:#0A3A2A;--fg:#A6893B"><span class="b-caps b-space">ROLEX</span></div>
        </div>
        <button class="b-arrow next" type="button" aria-label="Marque suivante">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
      <div class="b-dots" id="b-dots" aria-hidden="true"></div>
      <p class="b-caption">Toutes ces grandes marques ont commencé comme vous. <span class="hl-y">Par une idée.</span></p>
    </div>
  </div>
</section>
