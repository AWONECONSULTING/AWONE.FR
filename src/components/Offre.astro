<!-- ══════════════ L'OFFRE DU MOMENT — vidéo façon Apple TV ══════════════ -->
<section data-burst class="offer" id="offre" data-tint="cinema">
  <div class="burst" aria-hidden="true"><span class="b-comet" style="--bx:30%;--by:22%;--bd:0s;--c:var(--rose);--sx:-260px;--rot:-135deg"></span><span class="b-comet" style="--bx:72%;--by:26%;--bd:.22s;--c:var(--bleu-clair)"></span></div>
  <div class="wrap">
    <div class="head-zone">
      <p class="eyebrow reveal">L'offre du moment</p>
      <h2 class="sec reveal" data-i="1">L'offre du moment pour booster son business&nbsp;!</h2>
    </div>

    <div class="tv" id="tv">
      <!-- 🎬 VIDÉO : déposez le fichier "offre-awone.mp4" à côté de cette page (recommandé).
           En attendant, la page tente le lien direct Google Drive, puis bascule
           automatiquement sur le lecteur Drive si besoin. -->
      <video id="offer-video" muted loop playsinline autoplay preload="metadata">
        <source src="offre-awone.mp4" type="video/mp4">
        <source src="https://drive.google.com/uc?export=download&amp;id=1E2i66FOVV7U_dq_DwtVXibYF8Gk6aKbC" type="video/mp4">
      </video>
      <button class="sound" id="sound-btn" type="button" aria-label="Activer le son de la vidéo" aria-pressed="false">
        <svg class="ic-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
        </svg>
        <svg class="ic-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
        </svg>
        <span class="lbl">Activer le son</span>
      </button>
    </div>
    <div class="glow" aria-hidden="true"></div>
    <p class="hint reveal" data-i="2">La vidéo se lance sans le son — activez-le d'un clic, sans quitter la page.</p>
  </div>
</section>
