<!-- ══════════════ POUR QUI / PAS POUR QUI ══════════════ -->
<section data-burst id="pourqui" data-tint="space">
  <div class="burst" aria-hidden="true"><span class="b-comet" style="--bx:28%;--by:28%;--bd:0s;--c:var(--vert);--sx:-260px;--rot:-135deg"></span><span class="b-comet" style="--bx:74%;--by:40%;--bd:.2s;--c:var(--rose)"></span></div>
  <div class="wrap">
    <div class="reveal" style="text-align:center">
      <p class="eyebrow">En toute transparence</p>
      <h2 class="sec" style="margin:0 auto">AWONE est fait pour vous si…</h2>
    </div>
    <div class="fit-grid">
      <article class="fit yes reveal" data-i="0">
        <h3>C'est probablement adapté si…</h3>
        <ul>
          <li>Vous voulez structurer un projet sérieusement</li>
          <li>Vous cherchez une vision globale, pas une action isolée</li>
          <li>Vous voulez améliorer votre image, vos outils ou votre acquisition</li>
          <li>Vous avez besoin d'une équipe capable de comprendre le business autant que le design</li>
          <li>Vous êtes prêt à avancer avec méthode</li>
        </ul>
      </article>
      <article class="fit no reveal" data-i="1">
        <h3>Ce n'est peut-être pas adapté si…</h3>
        <ul>
          <li>Vous cherchez uniquement le prix le plus bas</li>
          <li>Vous voulez un simple logo sans réflexion autour</li>
          <li>Vous voulez lancer des actions sans clarifier l'offre</li>
          <li>Vous cherchez une solution magique immédiate</li>
          <li>Vous ne souhaitez pas prendre le temps de cadrer le projet</li>
        </ul>
      </article>
    </div>
    <p class="method-punch reveal">On préfère être transparents dès le départ : un bon accompagnement commence par une bonne compréhension du projet.</p>
  </div>
</section>
