---
/* CONFIG éditoriale : contenu et positions de la constellation desktop.
   Les positions sont exprimées en pourcentage du viewport épinglé. */
const steps = [
  {
    title: 'Comprendre',
    description: "Analyse du projet, du marché, des objectifs et du niveau d'avancement.",
    x: 14,
    y: 74,
    anchor: 'after',
  },
  {
    title: 'Structurer',
    description: "Clarification de l'offre, du positionnement, du message et de la stratégie.",
    x: 33,
    y: 60,
    anchor: 'after',
  },
  {
    title: 'Créer',
    description: 'Identité, contenus, site, tunnel, outils ou supports nécessaires.',
    x: 49,
    y: 43,
    anchor: 'after',
  },
  {
    title: 'Déployer',
    description: 'Mise en ligne, automatisations, acquisition, campagnes et suivi commercial.',
    x: 66,
    y: 31,
    anchor: 'before',
  },
  {
    title: 'Optimiser',
    description: 'Analyse, ajustements, amélioration continue et accompagnement dans la durée.',
    x: 82,
    y: 16,
    anchor: 'before',
  },
];
---

<!-- ══════════════ MÉTHODE — séquence 3D scrubée au scroll ══════════════ -->
<section
  id="methode"
  class="method-cinematic is-enhanced is-static"
  data-tint="cinema"
  data-frame-root="/frames/method"
  data-desktop-frames="181"
  data-mobile-frames="121"
  data-desktop-directory="desktop"
  data-mobile-directory="mobile-optimized"
  data-scroll-screens="5.8"
  data-scrub="0.6"
  aria-labelledby="method-cinematic-title"
>
  <h2 id="method-cinematic-title" class="method-visually-hidden">
    Notre méthode — Les 5 clés de la réussite
  </h2>

  <div class="method-cinematic-stage" data-method-stage>
    <!-- Poster permanent : le canvas peut être purgé sans laisser de vide. -->
    <picture class="method-cinematic-poster" aria-hidden="true">
      <source
        data-method-poster-source
        data-poster-srcset="/frames/method/mobile-optimized-avif/frame_0001.avif"
        media="(max-width: 767px), (max-width: 932px) and (max-height: 560px) and (pointer: coarse)"
        type="image/avif"
      >
      <source
        data-method-poster-source
        data-poster-srcset="/frames/method/desktop-avif/frame_0001.avif"
        type="image/avif"
      >
      <source
        data-method-poster-source
        data-poster-srcset="/frames/method/mobile-optimized/frame_0001.webp"
        media="(max-width: 767px), (max-width: 932px) and (max-height: 560px) and (pointer: coarse)"
        type="image/webp"
      >
      <source
        data-method-poster-source
        data-poster-srcset="/frames/method/desktop/frame_0001.webp"
        type="image/webp"
      >
      <img
        data-method-poster
        src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="
        data-poster-src="/frames/method/mobile-optimized/frame_0001.webp"
        alt=""
        width="720"
        height="405"
        loading="lazy"
        decoding="async"
        fetchpriority="low"
      >
    </picture>
    <noscript>
      <img
        class="method-cinematic-poster method-cinematic-poster-noscript"
        src="/frames/method/desktop/frame_0001.webp"
        alt=""
        width="1440"
        height="810"
        aria-hidden="true"
      >
    </noscript>
    <canvas class="method-cinematic-canvas" data-method-canvas aria-hidden="true"></canvas>
    <div class="method-cinematic-scrim" aria-hidden="true"></div>

    <div
      class="method-constellation"
      data-method-constellation
      role="list"
      aria-label="Les cinq étapes de la méthode AWONE"
    >
      {steps.slice(0, -1).map(() => <span class="method-connector" data-method-connector aria-hidden="true"></span>)}

      {steps.map((step, index) => (
        <article
          class:list={[
            'method-node',
            `method-node--${step.anchor}`,
            index === 0 ? 'is-active' : 'is-future',
          ]}
          data-method-node
          data-x={step.x}
          data-y={step.y}
          data-title={step.title}
          style={`--node-x:${step.x}%;--node-y:${step.y}%;`}
          role="listitem"
          aria-current={index === 0 ? 'step' : undefined}
        >
          <span class="method-node-dot" aria-hidden="true"></span>
          <div class="method-label">
            <span class="method-label-num" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="method-mobile-progress" data-method-progress aria-hidden="true">
      {steps.map((_, index) => (
        <i class={index === 0 ? 'is-active' : ''} data-method-progress-dot></i>
      ))}
    </div>

    <div class="method-loader" data-method-loader role="status" aria-label="Préparation de la séquence 3D">
      <div class="method-loader-copy">
        <span data-method-loader-label>Préparation de l’expérience</span>
        <strong data-method-loader-value>0%</strong>
      </div>
      <span
        class="method-loader-track"
        data-method-loader-track
        role="progressbar"
        aria-label="Chargement des images de la méthode"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="0"
      ><i></i></span>
    </div>

    <div class="method-veil method-veil--exit" data-method-exit-veil aria-hidden="true"></div>
    <p class="method-scroll-hint" data-method-hint aria-hidden="true">Défiler pour construire</p>
    <p class="method-visually-hidden" data-method-status aria-live="polite">Étape 1 sur 5 : Comprendre</p>
  </div>
</section>
