<!-- ══════════════ PÔLES ══════════════ -->
<section id="poles" class="sun" data-tint="soleil">
  <div class="wrap">
    <div class="reveal">
      <p class="eyebrow">Nos pôles</p>
      <h2 class="sec">Nos Services Sur Mesure.</h2>
      <p class="lead">AWONE active les bonnes expertises au bon moment. Chaque pôle est une étape utile dans la construction d'un projet solide.</p>
    </div>

    <div class="poles-grid">
      <article class="pole" data-i="0" style="--c:var(--jaune);--fx:-70px;--fy:30px;--d:0.00s">
        <span class="num">01</span>
        <div class="ic"><img class="vA" src="/icons/icon-1a.svg" alt="" width="72" height="72" loading="lazy" decoding="async"><img class="vB" src="/icons/icon-1b.svg" alt="" width="72" height="72" loading="lazy" decoding="async"></div>
        <h3>Stratégie &amp; Business</h3>
        <p>Positionnement, structuration d'offre, stratégie commerciale et optimisation du business model.</p>
      </article>
      <article class="pole" data-i="1" style="--c:var(--lavande);--fx:0;--fy:80px;--d:0.12s">
        <span class="num">02</span>
        <div class="ic"><img class="vA" src="/icons/icon-8a.svg" alt="" width="72" height="72" loading="lazy" decoding="async"><img class="vB" src="/icons/icon-8b.svg" alt="" width="72" height="72" loading="lazy" decoding="async"></div>
        <h3>Identité visuelle &amp; DA</h3>
        <p>Logo, charte graphique, direction artistique et cohérence de marque sur tous vos supports.</p>
      </article>
      <article class="pole" data-i="2" style="--c:var(--bleu);--fx:70px;--fy:30px;--d:0.24s">
        <span class="num">03</span>
        <div class="ic"><img class="vA" src="/icons/icon-3a.svg" alt="" width="72" height="72" loading="lazy" decoding="async"><img class="vB" src="/icons/icon-3b.svg" alt="" width="72" height="72" loading="lazy" decoding="async"></div>
        <h3>Sites web &amp; Landing pages</h3>
        <p>Sites optimisés marketing, landing pages et expériences pensées pour la conversion.</p>
      </article>
      <article class="pole" data-i="3" style="--c:var(--rose);--fx:90px;--fy:-20px;--d:0.36s">
        <span class="num">04</span>
        <div class="ic"><img class="vA" src="/icons/icon-4a.svg" alt="" width="72" height="72" loading="lazy" decoding="async"><img class="vB" src="/icons/icon-4b.svg" alt="" width="72" height="72" loading="lazy" decoding="async"></div>
        <h3>Tunnels &amp; Automatisation</h3>
        <p>Tunnels de vente, ERP, CRM, automatisations et outils métiers sur mesure.</p>
      </article>
      <article class="pole" data-i="4" style="--c:var(--bleu-clair);--fx:-90px;--fy:-20px;--d:0.18s">
        <span class="num">05</span>
        <div class="ic"><img class="vA" src="/icons/icon-5a.svg" alt="" width="72" height="72" loading="lazy" decoding="async"><img class="vB" src="/icons/icon-5b.svg" alt="" width="72" height="72" loading="lazy" decoding="async"></div>
        <h3>Shooting photo &amp; vidéo</h3>
        <p>Contenus photo et vidéo professionnels, VSL et supports qui valorisent votre marque.</p>
      </article>
      <article class="pole" data-i="5" style="--c:var(--creme);--fx:-40px;--fy:70px;--d:0.30s">
        <span class="num">06</span>
        <div class="ic"><img class="vA" src="/icons/icon-6a.svg" alt="" width="72" height="72" loading="lazy" decoding="async"><img class="vB" src="/icons/icon-6b.svg" alt="" width="72" height="72" loading="lazy" decoding="async"></div>
