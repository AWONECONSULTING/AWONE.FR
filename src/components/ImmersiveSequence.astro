---
/* Texte éditorial de la séquence — volontairement centralisé ici pour
   pouvoir être ajusté sans toucher au canvas ni à l'animation. */
const eyebrow = 'Immersive · Motion';
const title = 'On élève votre marque.';
const subtitle = 'Embarquez dans le train avec votre équipe dédiée AWONE';
---

<!-- ══════════════ SÉQUENCE IMMERSIVE AU SCROLL ══════════════ -->
<section
  class="immersive-sequence is-static"
  id="immersion"
  data-tint="cinema"
  data-frame-root="/frames/immersive"
  data-desktop-frames="181"
  data-mobile-frames="91"
  data-desktop-directory="desktop"
  data-mobile-directory="mobile-optimized"
  data-desktop-scroll-screens="3.2"
  data-mobile-scroll-screens="2.4"
  data-desktop-scrub="0.65"
  data-mobile-scrub="0.55"
  aria-labelledby="immersive-title"
>
  <div class="immersive-stage" data-immersive-stage>
    <!-- Poster léger permanent : il reste visible pendant un rechargement ou
         après une purge mémoire, afin qu'un canvas 1×1 ne crée jamais de noir. -->
    <picture class="immersive-poster">
      <source
        data-immersive-poster-avif
        data-poster-srcset="/frames/immersive/poster-mobile.avif"
        type="image/avif"
      >
      <source
        data-immersive-poster-webp
        data-poster-srcset="/frames/immersive/poster-mobile.webp"
        type="image/webp"
      >
      <img
        data-immersive-poster
        src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="
        data-poster-src="/frames/immersive/poster-mobile.webp"
        alt="Ascension au-dessus des nuages dans une scène cinématographique dorée"
        width="360"
        height="645"
        loading="lazy"
        decoding="async"
        fetchpriority="low"
      >
    </picture>
    <noscript>
      <img
        class="immersive-poster immersive-poster-noscript"
        src="/frames/immersive/poster-mobile.webp"
        alt="Ascension au-dessus des nuages dans une scène cinématographique dorée"
        width="360"
        height="645"
      >
    </noscript>
    <canvas class="immersive-canvas" data-immersive-canvas aria-hidden="true"></canvas>
    <div class="immersive-shade" aria-hidden="true"></div>
    <div class="immersive-transition-wash" aria-hidden="true"></div>

    <div class="immersive-copy">
      <p class="immersive-eyebrow">{eyebrow}</p>
      <h2 id="immersive-title">{title}</h2>
      <p class="immersive-subtitle">{subtitle}</p>
    </div>

    <div class="immersive-loader" role="status" aria-live="polite">
      <span class="immersive-loader-label">Préparation de l'ascension</span>
      <span
        class="immersive-loader-track"
        role="progressbar"
        aria-label="Chargement des images de l'ascension"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="0"
      ><i></i></span>
      <span class="immersive-loader-value">0%</span>
    </div>

    <p class="immersive-hint" aria-hidden="true">
      <span>Défiler pour s'élever</span>
      <i></i>
    </p>

    <div class="immersive-exit" aria-hidden="true">
      <div class="immersive-spinner">
        <span class="immersive-spinner-ring immersive-spinner-ring-a"></span>
        <span class="immersive-spinner-ring immersive-spinner-ring-b"></span>
        <img
          class="immersive-spinner-logo"
          src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="
          data-src="/assets/logo-awone.webp"
          data-srcset="/assets/logo-awone-600.webp 600w, /assets/logo-awone.webp 900w"
          sizes="(max-width: 760px) min(68vw, 300px), min(35vw, 470px)"
          alt=""
          width="900"
          height="155"
          loading="lazy"
          decoding="async"
        >
      </div>
      <span class="immersive-exit-label">La suite · Nos pôles</span>
    </div>
  </div>
</section>
